Menu="Utilities"
Title="LUKS Key Management"
Icon="key"
---
<?
# This space is intentionally left for any future PHP logic if needed.
# For now, all logic is handled by the backend PHP scripts via AJAX.
?>
<div class="section">
  <h2>LUKS Auto-Unlock for Encrypted Arrays and Pools</h2>
  <p>This tool manages a hardware-bound LUKS key that's dynamically generated from your router's MAC address and motherboard ID. Your original passphrase remains valid, and no keys are stored on disk.</p>

  <!-- Tab Navigation -->
  <div class="tab-container">
    <div class="tab-buttons" style="border-bottom: 1px solid #444; margin-bottom: 20px;">
      <button class="tab-btn active" data-tab="autostart" style="background: #333; color: #fff; border: 1px solid #555; padding: 10px 20px; margin-right: 5px; cursor: pointer;">Auto Start</button>
      <button class="tab-btn" data-tab="headers" style="background: #222; color: #ccc; border: 1px solid #555; padding: 10px 20px; margin-right: 5px; cursor: pointer;">LUKS Headers</button>
      <button class="tab-btn" data-tab="gofile" style="background: #222; color: #ccc; border: 1px solid #555; padding: 10px 20px; margin-right: 5px; cursor: pointer;">Go File</button>
      <button class="tab-btn" data-tab="encinfo" style="background: #222; color: #ccc; border: 1px solid #555; padding: 10px 20px; margin-right: 5px; cursor: pointer;">Encryption Info</button>
      <button class="tab-btn" data-tab="status" style="background: #222; color: #ccc; border: 1px solid #555; padding: 10px 20px; cursor: pointer;">Status</button>
    </div>

    <!-- Tab Content -->
    <div class="tab-content">
      <!-- Auto Start Tab -->
      <div id="autostart-tab" class="tab-pane active">
        <p>This tool provides complete auto-unlock setup in one action. It will backup your LUKS headers, refresh the hardware-derived key, and automatically enable auto-unlock at boot.</p>
        <p>Manual unlock is always possible using your original passphrase. Auto-unlock only works when the server runs on the original hardware and router.</p>
        
        <form id="autostartForm">
          <!-- LUKS Management Section -->
          <h3>Complete Auto-Unlock Setup</h3>
          <dl>
            <dt><strong>Passphrase:</strong></dt>
            <dd>
              <input type="password" id="passphrase" name="passphrase" class="short" required>
              <div class="description">Enter your original LUKS encryption key.</div>
            </dd>

            <dt><strong>Header Backup Location:</strong></dt>
            <dd>
              <select id="backupLocation" name="backupLocation">
                <option value="download" selected>Download to PC</option>
                <option value="yes">Save to server</option>
              </select>
              <div class="description">LUKS headers will always be backed up for safety. Choose where to save the encrypted backup.</div>
            </dd>

            <dt><strong>Dry Run:</strong></dt>
            <dd>
              <select id="dryRun" name="dryRun">
                <option value="yes" selected>Yes</option>
                <option value="no">No</option>
              </select>
              <div class="description">Simulates the process without making changes. Select 'No' to apply changes.</div>
            </dd>
          </dl>
          <p>
            <button type="button" onclick="runAutoStartSetup()">Enable Auto-Unlock</button>
          </p>
          
          <div style="margin-top: 15px; padding: 10px; background: #2a2a2a; border-radius: 5px; border-left: 4px solid #4CAF50;">
            <strong>This will:</strong>
            <ul style="margin: 5px 0; padding-left: 20px;">
              <li>Backup LUKS headers to your chosen location</li>
              <li>Refresh hardware-derived key on all devices</li>
              <li>Automatically enable auto-unlock in go file</li>
            </ul>
          </div>
        </form>
      </div>

      <!-- LUKS Headers Tab -->
      <div id="headers-tab" class="tab-pane" style="display: none;">
        <p>Create encrypted backups of your LUKS headers for all devices that your passphrase can unlock. These backups are essential for recovery if headers become corrupted.</p>
        
        <form id="headersForm">
          <h3>Backup LUKS Headers</h3>
          <dl>
            <dt><strong>Passphrase:</strong></dt>
            <dd>
              <input type="password" id="headersPassphrase" name="headersPassphrase" class="short" required>
              <div class="description">Enter your LUKS encryption key. All devices this passphrase unlocks will be backed up.</div>
            </dd>

            <dt><strong>Backup Location:</strong></dt>
            <dd>
              <select id="headersBackupLocation" name="headersBackupLocation">
                <option value="yes" selected>Save to server</option>
                <option value="download">Download to browser</option>
              </select>
              <div class="description">Choose to save the encrypted backup on the server or download it to your computer.</div>
            </dd>

            <dt><strong>Dry Run:</strong></dt>
            <dd>
              <select id="headersDryRun" name="headersDryRun">
                <option value="yes" selected>Yes</option>
                <option value="no">No</option>
              </select>
              <div class="description">Simulates the backup process without creating files. Select 'No' to create actual backups.</div>
            </dd>
          </dl>
          <p>
            <button type="button" onclick="runHeadersBackup()">Backup Headers</button>
          </p>
        </form>
      </div>

      <!-- Go File Tab -->
      <div id="gofile-tab" class="tab-pane" style="display: none;">
        <p>Control auto-unlock functionality by managing the startup configuration in your go file. This allows you to enable or disable auto-unlock without affecting your LUKS keys.</p>
        
        <form id="gofileForm">
          <h3>Boot Auto-Unlock Control</h3>
          <dl>
            <dt><strong>Action:</strong></dt>
            <dd>
              <select id="goAction" name="goAction">
                <option value="add" selected>Enable auto-unlock at boot</option>
                <option value="remove">Disable auto-unlock at boot</option>
              </select>
              <div class="description">Choose whether to enable or disable automatic LUKS unlocking during system startup.</div>
            </dd>
          </dl>
          <p>
            <button type="button" onclick="runGoCommand()">Update Boot Configuration</button>
          </p>
          
          <div style="margin-top: 15px; padding: 10px; background: #2a2a2a; border-radius: 5px; border-left: 4px solid #2196F3;">
            <strong>Note:</strong> This only controls whether auto-unlock runs at boot. It does not affect your LUKS keys or hardware key configuration. Use this to temporarily disable auto-unlock or re-enable it after maintenance.
          </div>
        </form>
      </div>

      <!-- Encryption Info Tab -->
      <div id="encinfo-tab" class="tab-pane" style="display: none;">
        <p>View detailed information about LUKS encryption on your server. This provides insight into encrypted drives, slot usage, and key configurations.</p>
        
        <form id="encinfoForm">
          <h3>Encryption Analysis</h3>
          <dl>
            <dt><strong>Passphrase:</strong></dt>
            <dd>
              <input type="password" id="encinfoPassphrase" name="encinfoPassphrase" class="short" required>
              <div class="description">Enter your LUKS encryption key to analyze encrypted drives and slots.</div>
            </dd>

            <dt><strong>Detail Level:</strong></dt>
            <dd>
              <select id="detailLevel" name="detailLevel">
                <option value="simple" selected>Simple (drive list only)</option>
                <option value="detailed">Detailed (slots and metadata)</option>
              </select>
              <div class="description">Choose how much information to display about your encrypted drives.</div>
            </dd>

            <dt><strong>Dry Run:</strong></dt>
            <dd>
              <select id="encinfoDryRun" name="encinfoDryRun">
                <option value="yes" selected>Yes</option>
                <option value="no">No</option>
              </select>
              <div class="description">Dry run mode for testing - no actual operations performed.</div>
            </dd>
          </dl>
          <p>
            <button type="button" onclick="runEncryptionInfo()">View Encryption Status</button>
            <button type="button" onclick="downloadEncryptionInfo()" style="margin-left: 10px; background: #4CAF50; color: white; border: 1px solid #45a049; padding: 8px 16px; cursor: pointer;">Download Analysis</button>
          </p>
          
          <div style="margin-top: 15px; padding: 10px; background: #2a2a2a; border-radius: 5px; border-left: 4px solid #FF9800;">
            <strong>Security Note:</strong> Your passphrase is required to access LUKS metadata. This is read-only analysis and makes no changes to your encryption configuration.
          </div>
        </form>
      </div>

      <!-- Status Tab -->
      <div id="status-tab" class="tab-pane" style="display: none;">
        <p>Operation output and status information will be displayed here. Switch to this tab during operations to monitor progress.</p>
        
        <h3>Current Operation Status</h3>
        <div style="margin-bottom: 10px;">
          <button type="button" onclick="clearStatus()" style="background: #444; color: #fff; border: 1px solid #666; padding: 5px 15px; cursor: pointer;">Clear Output</button>
        </div>
        <pre id="statusOutput" style="background-color: #1a1a1a; color: #fff; padding: 15px; border-radius: 5px; min-height: 400px; max-height: 600px; overflow-y: auto; white-space: pre-wrap; word-wrap: break-word; font-family: 'Courier New', monospace; font-size: 12px; border: 1px solid #444;">No operations performed yet. Output from all plugin operations will appear here.</pre>
      </div>
    </div>
  </div>
</div>

<script>
  // Tab switching functionality
  document.addEventListener('DOMContentLoaded', function() {
    // Add click listeners to tab buttons
    const tabButtons = document.querySelectorAll('.tab-btn');
    tabButtons.forEach(button => {
      button.addEventListener('click', function() {
        switchTab(this.dataset.tab);
      });
    });
  });

  function switchTab(tabName) {
    // Hide all tab panes
    const tabPanes = document.querySelectorAll('.tab-pane');
    tabPanes.forEach(pane => {
      pane.style.display = 'none';
    });

    // Remove active class from all buttons
    const tabButtons = document.querySelectorAll('.tab-btn');
    tabButtons.forEach(button => {
      button.classList.remove('active');
      button.style.background = '#222';
      button.style.color = '#ccc';
    });

    // Show selected tab and activate button
    document.getElementById(tabName + '-tab').style.display = 'block';
    const activeButton = document.querySelector(`[data-tab="${tabName}"]`);
    activeButton.classList.add('active');
    activeButton.style.background = '#333';
    activeButton.style.color = '#fff';
  }

  // Unified status output functions
  function updateStatus(message) {
    const statusOutput = document.getElementById('statusOutput');
    statusOutput.textContent += message + '\n';
    statusOutput.scrollTop = statusOutput.scrollHeight;
  }

  function setStatus(message) {
    const statusOutput = document.getElementById('statusOutput');
    statusOutput.textContent = message + '\n';
    statusOutput.scrollTop = statusOutput.scrollHeight;
  }

  function clearStatus() {
    document.getElementById('statusOutput').textContent = 'Output cleared.\n';
  }

  function runAutoStartSetup() {
    const passphrase = document.getElementById('passphrase').value;
    const backupLocation = document.getElementById('backupLocation').value;
    const dryRun = document.getElementById('dryRun').value;

    if (!passphrase) {
      setStatus('Error: Passphrase is required.');
      return;
    }

    // Auto-switch to Status tab to show operation progress
    switchTab('status');
    setStatus('Starting complete auto-unlock setup...\nThis will backup headers, refresh hardware key, and enable auto-unlock.\nExecuting LUKS management script, please wait...');

    // Convert backupLocation to the format expected by the backend
    const backupHeaders = backupLocation === 'download' ? 'download' : 'yes';

    $.post('/plugins/luks-key-management/scripts/run_luks_script.php', {
      passphrase: passphrase,
      backupHeaders: backupHeaders,
      dryRun: dryRun
    }, function(data) {
      setStatus(data);
      
      // Check if we need to download a backup file
      if (backupLocation === 'download' && dryRun === 'no') {
        // Look for download ready indicator in the output
        const downloadMatch = data.match(/DOWNLOAD_READY: (.+)/);
        if (downloadMatch) {
          const downloadPath = downloadMatch[1];
          const filename = downloadPath.split('/').pop();
          downloadBackupFile(filename);
        }
      }
    }).fail(function() {
      setStatus('Error: Failed to execute the auto-unlock setup. Check browser console for more details.');
    });
  }

  function downloadBackupFile(filename) {
    // Create direct download link - file is accessible via plugin downloads directory
    const downloadUrl = '/plugins/luks-key-management/downloads/' + filename;
    
    // Create a temporary anchor element to trigger download
    const link = document.createElement('a');
    link.href = downloadUrl;
    link.download = filename;
    link.style.display = 'none';
    
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    
    // Update status to inform user
    updateStatus('\nBackup file download initiated. Check your browser\'s download folder.');
    
    // Clean up the temporary file after a delay
    setTimeout(function() {
      fetch('/plugins/luks-key-management/scripts/cleanup_download.php', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'filename=' + encodeURIComponent(filename)
      });
    }, 5000); // 5 second delay to ensure download completes
  }

  function runGoCommand() {
    const action = document.getElementById('goAction').value;

    // Auto-switch to Status tab to show operation progress
    switchTab('status');
    setStatus('Starting go file configuration...\nExecuting startup script configuration, please wait...');

    $.post('/plugins/luks-key-management/scripts/run_go_script.php', {
      action: action
    }, function(data) {
      setStatus(data);
    }).fail(function() {
      setStatus('Error: Failed to execute the go file script. Check browser console for more details.');
    });
  }

  function runHeadersBackup() {
    const passphrase = document.getElementById('headersPassphrase').value;
    const backupLocation = document.getElementById('headersBackupLocation').value;
    const dryRun = document.getElementById('headersDryRun').value;

    if (!passphrase) {
      setStatus('Error: Passphrase is required for LUKS headers backup.');
      return;
    }

    // Auto-switch to Status tab to show operation progress
    switchTab('status');
    setStatus('Starting LUKS headers backup operation...\nExecuting LUKS headers backup script, please wait...');

    // Use the same backend but with headers-only flags
    const backupMode = backupLocation === 'download' ? 'download' : 'yes';
    
    $.post('/plugins/luks-key-management/scripts/run_luks_script.php', {
      passphrase: passphrase,
      backupHeaders: backupMode,
      dryRun: dryRun,
      headersOnly: 'true' // Flag to indicate this is headers-only operation
    }, function(data) {
      setStatus(data);
      
      // Check if we need to download a backup file
      if (backupLocation === 'download' && dryRun === 'no') {
        // Look for download ready indicator in the output
        const downloadMatch = data.match(/DOWNLOAD_READY: (.+)/);
        if (downloadMatch) {
          const downloadPath = downloadMatch[1];
          const filename = downloadPath.split('/').pop();
          downloadBackupFile(filename);
        }
      }
    }).fail(function() {
      setStatus('Error: Failed to execute the LUKS headers backup script. Check browser console for more details.');
    });
  }

  function runEncryptionInfo() {
    const passphrase = document.getElementById('encinfoPassphrase').value;
    const detailLevel = document.getElementById('detailLevel').value;
    const dryRun = document.getElementById('encinfoDryRun').value;

    if (!passphrase) {
      setStatus('Error: Passphrase is required for encryption analysis.');
      return;
    }

    // Auto-switch to Status tab to show operation progress
    switchTab('status');
    setStatus('Starting encryption analysis...\nAnalyzing LUKS encrypted drives and slot configurations, please wait...');

    $.post('/plugins/luks-key-management/scripts/run_encryption_info.php', {
      passphrase: passphrase,
      detailLevel: detailLevel,
      dryRun: dryRun
    }, function(data) {
      setStatus(data);
    }).fail(function() {
      setStatus('Error: Failed to execute encryption analysis. Check browser console for more details.');
    });
  }

  function downloadEncryptionInfo() {
    const passphrase = document.getElementById('encinfoPassphrase').value;
    const detailLevel = document.getElementById('detailLevel').value;
    const dryRun = document.getElementById('encinfoDryRun').value;

    if (!passphrase) {
      setStatus('Error: Passphrase is required for encryption analysis download.');
      return;
    }

    if (dryRun === 'yes') {
      setStatus('Error: Cannot download analysis in dry run mode. Set dry run to "No" to download.');
      return;
    }

    // Auto-switch to Status tab to show operation progress
    switchTab('status');
    setStatus('Preparing encryption analysis for download...\nGenerating encrypted analysis file, please wait...');

    $.post('/plugins/luks-key-management/scripts/run_encryption_download.php', {
      passphrase: passphrase,
      detailLevel: detailLevel
    }, function(data) {
      setStatus(data);
      
      // Check if we need to download the analysis file
      const downloadMatch = data.match(/DOWNLOAD_READY: (.+)/);
      if (downloadMatch) {
        const downloadPath = downloadMatch[1];
        const filename = downloadPath.split('/').pop();
        downloadAnalysisFile(filename);
      }
    }).fail(function() {
      setStatus('Error: Failed to generate encryption analysis download. Check browser console for more details.');
    });
  }

  function downloadAnalysisFile(filename) {
    // Create direct download link - file is accessible via plugin downloads directory
    const downloadUrl = '/plugins/luks-key-management/downloads/' + filename;
    
    // Create a temporary anchor element to trigger download
    const link = document.createElement('a');
    link.href = downloadUrl;
    link.download = filename;
    link.style.display = 'none';
    
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    
    // Update status to inform user
    updateStatus('\nEncryption analysis download initiated. Check your browser\'s download folder.');
    
    // Clean up the temporary file after a delay
    setTimeout(function() {
      fetch('/plugins/luks-key-management/scripts/cleanup_download.php', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'filename=' + encodeURIComponent(filename)
      });
    }, 5000); // 5 second delay to ensure download completes
  }
</script>
